RewriteEngine On

# Allow real files/folders
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
 
RewriteRule ^career career.php?slug=$1 [L,QSA]
RewriteRule ^services services.php?slug=$1 [L,QSA]
RewriteRule ^portfolio portfolio.php?slug=$1 [L,QSA]
RewriteRule ^about about.php?slug=$1 [L,QSA]
RewriteRule ^contact-us contact-us.php?slug=$1 [L,QSA]
RewriteRule ^terms-of-conditions terms-of-conditions.php?slug=$1 [L,QSA]
RewriteRule ^privacy-policy privacy-policy.php?slug=$1 [L,QSA]
RewriteRule ^cookie-policy cookie-policy.php?slug=$1 [L,QSA]
